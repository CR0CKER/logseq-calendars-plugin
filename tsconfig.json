{
  // Type-check configuration for `npm run typecheck` (tsc --noEmit).
  // Parcel does the actual build/transpile; this config exists purely to gate types.
  // The codebase is strict-clean (0 errors) as of the H2 extraction, so the CI
  // typecheck step is a blocking gate. Keep it green.
  "compilerOptions": {
    "target": "ES2021",
    "module": "ESNext",
    "moduleResolution": "node",
    "lib": ["ES2021", "DOM"],
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "strict": true
  },
  "include": ["index.ts", "parsing.ts", "recurrence.ts", "types/**/*.d.ts"]
}
